# Copy this file to .env and fill in real values before running the server.
# .env is git-ignored — never commit real secrets.

# Used to sign/verify login tokens. Use a long, random string in production.
# Generate one quickly with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

PORT=4000